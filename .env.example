# ═══════════════════════════════════════════
# LINE Messaging API
# ═══════════════════════════════════════════
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
ADMIN_LINE_USER_ID=

# ═══════════════════════════════════════════
# サーバー設定
# ═══════════════════════════════════════════
PORT=3000
SERVER_URL=   # 例: https://xxxx.ngrok-free.app（PDFリンクをLINEに送る場合に設定）

# ═══════════════════════════════════════════
# 発行者情報（請求書PDF に印字）
# ═══════════════════════════════════════════
COMPANY_NAME=株式会社〇〇材木店
COMPANY_ADDRESS=〒000-0000 ○○県○○市○○町1-1
COMPANY_TEL=00-0000-0000
COMPANY_BANK=○○銀行 △△支店 普通 1234567

# ═══════════════════════════════════════════
# Google Sheets 連携（任意）
# ═══════════════════════════════════════════
# 設定しない場合は Sheets 連携が無効になるだけで他機能に影響なし
GOOGLE_SERVICE_ACCOUNT_EMAIL=   # 例: myservice@myproject.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=             # JSONキーの private_key をそのままペースト（\n はそのまま）
GOOGLE_SPREADSHEET_ID=          # スプレッドシートURLの /d/XXXXXXX/edit の XXXXXXX 部分

# ═══════════════════════════════════════════
# Gmail 送信連携（任意）
# ═══════════════════════════════════════════
# 設定しない場合はメール送信が無効になるだけで他機能に影響なし
# リフレッシュトークンの取得: node src/utils/getGmailToken.js
GMAIL_USER=           # 送信元のGmailアドレス 例: info@example.com
GMAIL_CLIENT_ID=      # OAuth2 クライアントID（Google Cloud Console で取得）
GMAIL_CLIENT_SECRET=  # OAuth2 クライアントシークレット（Google Cloud Console で取得）
GMAIL_REFRESH_TOKEN=  # OAuth2 リフレッシュトークン（node src/utils/getGmailToken.js で取得）
